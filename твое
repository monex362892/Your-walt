<!DOCTYPE html>
<html lang="ru">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Cirque</title>

<style>
body {
    margin: 0;
    background: black;
    color: white;
    font-family: Arial;
    height: 100vh;
    display: flex;
    justify-content: center;
    align-items: center;
    flex-direction: column;
    text-align: center;
}

#box {
    display: flex;
    flex-direction: column;
    gap: 15px;
    align-items: center;
}

input {
    padding: 18px;
    font-size: 22px;
    width: 80vw;
    max-width: 320px;
    border: 2px solid white;
    background: black;
    color: white;
    text-align: center;
    outline: none;
}

button {
    padding: 18px;
    font-size: 22px;
    width: 80vw;
    max-width: 320px;
    background: white;
    border: none;
    cursor: pointer;
}

#msg {
    margin-top: 25px;
    font-size: 26px;
}
</style>
</head>

<body>

<div id="box">
    <input id="code" placeholder="Сделать выбор">
    <button onclick="check()">Запустить ???</button>
</div>

<div id="msg"></div>

<script>
const correctCode = "1941";

function check() {
    const val = document.getElementById("code").value;
    const msg = document.getElementById("msg");

    if (val === correctCode) {
        window.location.href = "puzzle.html";
    } else {
        msg.innerText = "Ты делаешь не правельный выбор.";
    }
}
</script>

</body>
</html>